# Thunder OAuth client used for user sign-in in the Wayfinder web app.
# This is the WAYFINDER application — separate from the chat agent's client.
VITE_THUNDER_CLIENT_ID=WAYFINDER
# App ID used for embedded /flow/execute calls (native auth mode).
# Typically matches the application's handle in thunderid-config.yaml.
VITE_THUNDER_APP_ID=wayfinder-app
VITE_THUNDER_BASE_URL=https://localhost:8090

# Auth mode configuration.
# Set VITE_AUTH_IS_REDIRECT_BASED=false to enable the app-native embedded flow.
# When false, users authenticate via direct /flow/execute calls rendered inside the app.
# When true (default), the standard OAuth2 redirect flow is used via ThunderIDProvider.
VITE_AUTH_IS_REDIRECT_BASED=true

# Only relevant when VITE_AUTH_IS_REDIRECT_BASED=false.
# Set to true for managed (SDK-driven) embedded flow: the ThunderID SDK orchestrates the flow
# loop and exposes EmbeddedFlowComponent[] trees; the app renders custom UI from those trees.
# Set to false (default) for step-by-step embedded flow: the app drives the loop directly via
# raw /flow/execute calls and renders forms from the server's inputs[]/actions[] arrays.
VITE_AUTH_IS_VERBOSE=false
