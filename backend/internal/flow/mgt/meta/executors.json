                "displayName": "Allow Registration With Existing User",
                "type": "boolean",
                "required": false,
                "description": "Allow the registration flow to complete successfully when an existing user account is found instead of failing with a duplicate-user error."
            },
            {
                "name": "allowCrossOUProvisioning",
                "displayName": "Allow Cross-OU Provisioning",
                "type": "boolean",
                "required": false,
                "description": "Allow provisioning to proceed when the resolved organization unit differs from the existing user's organization unit."
            }
        ]
