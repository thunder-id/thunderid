{
  "private": true,
  "name": "@thunderid/frontend",
  "version": "0.0.0",
  "description": "Frontend workspace for ⚡️ ThunderID",
  "author": "WSO2",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/thunder-id/thunderid/tree/main/frontend#readme",
  "bugs": {
    "url": "https://github.com/thunder-id/thunderid/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thunder-id/thunderid"
  },
  "keywords": [
    "thunderid",
    "frontend",
    "workspace",
    "wso2"
  ],
  "scripts": {
    "build:apps": "turbo run build --filter=./apps/*",
    "build:packages": "turbo run build --filter=./packages/*",
    "clean": "pnpm clean:node_modules",
    "clean:node_modules": "rimraf node_modules",
    "dev": "turbo run dev --filter=./apps/*",
    "test:packages": "turbo run test --filter=./packages/* --concurrency=3",
    "i18n:extract": "pnpm i18next-cli sync"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@thunderid/eslint-plugin": "workspace:^",
    "@thunderid/logger": "workspace:^",
    "@thunderid/prettier-config": "workspace:^",
    "i18next-cli": "1.51.3",
    "rimraf": "catalog:",
    "turbo": "catalog:"
  }
}
