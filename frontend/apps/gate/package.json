    "@thunderid/i18n": "workspace:^",
    "@thunderid/hooks": "workspace:^",
    "@thunderid/utils": "workspace:^",
    "@wso2/oxygen-ui": "catalog:",
    "@wso2/oxygen-ui-icons-react": "catalog:",
    "dompurify": "catalog:",
    "i18next": "catalog:",
