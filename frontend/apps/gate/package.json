{
  "private": true,
  "name": "@thunderid/gate",
  "version": "0.0.0",
  "description": "⚡️ ThunderID Gate Application - The main app handles gateway operations such as authentication, registrations and account recovery in ThunderID.",
  "keywords": [
    "thunderid",
    "gate",
    "app",
    "wso2"
  ],
  "homepage": "https://github.com/thunder-id/thunderid/tree/main/frontend/apps/gate#readme",
