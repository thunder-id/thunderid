{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "modules/**"]
    },
    "@thunderid/docs#build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"],
      "env": ["DOCUSAURUS_URL", "DOCUSAURUS_BASE_URL"]
    },
    "@thunderid/eslint-plugin#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@thunderid/prettier-config#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
