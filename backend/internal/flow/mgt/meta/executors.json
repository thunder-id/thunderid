            {
                "name": "allowAuthenticationWithoutLocalUser",
                "displayName": "Allow Authentication Without Local User",
                "type": "boolean",
                "required": false,
                "description": "Allow the authentication flow to proceed even when no matching local user account exists. Useful when a downstream provisioning step will create the user."
