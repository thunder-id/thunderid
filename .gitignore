# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.db
*/**/executables/*

# sqlite database files
*.db-shm
*.db-wal

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Go workspace file
go.work
go.work.sum

# OS generated files
.DS_Store
Thumbs.db

# Server certificates.
*.pem
*.key
*.crt
*.cert
# Exception: test fixtures checked into testdata/ directories must be tracked.
# See tests/integration/testutils/testdata/mock_google_oidc_key.pem for rationale.
!**/testdata/*.pem
!**/testdata/*.key
!**/testdata/*.crt
!**/testdata/*.cert

# Runtime secrets generated by setup.sh (e.g. the Direct Auth Secret).
**/config/secrets/

# IDE settings, swap files, and temporary artifacts
.idea
*.swp
*.swo
*~
*.tgz
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Misc
.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings
.vitest-attachments

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Turborepo artifacts
.turbo
**/.turbo

# typescript
*.tsbuildinfo
next-env.d.ts

# next.js artifacts
.next

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Project compiled output folders
build
target
dist
tmp
out
out-tsc
backend/bin
backend/server

# E2E extracted distribution
tests/e2e/distribution/
frontend/packages/*/modules
samples/apps/*/server/app

# Test coverage reports
backend/coverage_unit.out
backend/coverage_unit.html

# Generated API specs and Postman collections (produced by merge-openapi-specs.mjs)
docs/static/api/combined.yaml
docs/static/api/next/combined.yaml
docs/static/api/next/postman/

# Playwright
.playwright-cli/

# Claude Code (local settings only — skills are shared via a symlink to .agent/skills)
.claude/*
!.claude/skills

# Dev-only CORS seed staged by `build.sh run` / `build.ps1 run` for the bootstrap one-shot (never committed or packaged)
backend/cmd/server/bootstrap/02-server-configurations.yaml

