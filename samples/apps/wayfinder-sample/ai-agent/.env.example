# --- LLM Provider ---
# Which LLM to use: "anthropic" (default) or "google".
LLM_PROVIDER=anthropic

# LLM API key obtained from your LLM provider.
LLM_API_KEY=your-llm-api-key

# Model name override. Defaults to claude-sonnet-4-6 (Anthropic) or gemini-3.1-flash-lite (Gemini).
# MODEL_NAME=

# --- Thunder ---
# Thunder runs on https://localhost:8090 by default. The Wayfinder Server
# requires a valid Thunder-issued token on every request; set
# API_REQUIRE_AUTH=false in backend/.env to bypass for local development.
THUNDER_BASE_URL=https://localhost:8090

# OAuth client ID and secret of the agent created in Thunder.
# The default secret matches thunderid-config/thunderid.env.
AGENT_ID=WAYFINDER-CONCIERGE
AGENT_SECRET=wayfinder-agent-secret

# Upgrade agent — CIBA-only client used by the upgrade scheduler to initiate
# backchannel authentication for users with pending upgrade requests.
# Kept separate from AGENT_ID because auth_flow_handle is shared between
# authorization_code and CIBA — they require different flows.
# The default values match thunderid-config/thunderid.env.
UPGRADE_AGENT_ID=WAYFINDER-UPGRADE-AGENT
UPGRADE_AGENT_SECRET=wayfinder-upgrade-agent-secret

# Redirect URI used for the on-behalf-of (user-context) authorization-code flow.
AGENT_REDIRECT_URI=http://localhost:5173/agent-callback

# Resource indicator for tokens the agent uses to call the Wayfinder MCP server.
# Must match the wayfinder-booking resource server identifier.
MCP_SERVER_URL=http://localhost:8787/mcp

# Scope required on the user's token to connect to the chat WebSocket.
# Must match a permission on the Wayfinder Agent resource server. The frontend
# requests this token with resource=http://localhost:8790/chat.
AGENT_ACCESS_SCOPE=agent:access

# Set to "true" to start the background upgrade scheduler that polls for pending upgrade
# requests and processes them via CIBA. Disabled by default — enable only when the CIBA
# email or SMS flow is fully configured in ThunderID.
UPGRADE_SCHEDULER_ENABLED=false

# CIBA hint type used by the upgrade scheduler to identify the user at bc-authorize.
# Options: "login_hint" (default, uses email) or "id_token_hint" (uses the user's ID token).
# For id_token_hint, set CIBA_LOGIN_HINT_ATTRIBUTE=userID in thunderid-config/thunderid.env
# so the CIBA flow resolves the hint as an entity ID instead of email.
CIBA_HINT_TYPE=login_hint
