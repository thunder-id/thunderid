# JWT validation and per-route scope enforcement are on by default.
# Set this to "false" to bypass auth and use a local demo user (dev only).
# API_REQUIRE_AUTH=false

# ThunderID base URL — used for JWKS fetch and as the default issuer.
THUNDER_BASE_URL=https://localhost:8090

# MCP tool authorization. Scope checks remain the default.
AUTHORIZATION_MODE=scope

# Required only when AUTHORIZATION_MODE=authzen.
THUNDERID_DIRECT_AUTH_SECRET=wayfinder-direct-auth-secret
