{
  "id": "backend",
  "displayName": "Backend",
  "description": "Machine-to-machine backend service",
  "creationFlow": {
    "steps": ["STACK", "NAME", "ORGANIZATION_UNIT", "COMPLETE"]
  },
  "defaults": {
    "name": "Backend Application",
    "inboundAuthConfig": [
      {
        "type": "oauth2",
        "config": {
          "grantTypes": ["client_credentials"],
          "pkceRequired": false,
          "tokenEndpointAuthMethod": "client_secret_basic",
          "publicClient": false
        }
      }
    ]
  }
}
