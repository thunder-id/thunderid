{
  "name": "@thunderid/react",
  "version": "0.2.0",
  "description": "React SDK for ThunderID",
  "keywords": [
    "thunderid",
    "react",
    "spa"
  ],
  "homepage": "https://github.com/thunder-id/thunderid/tree/main/sdks/react#readme",
  "bugs": {
    "url": "https://github.com/thunder-id/thunderid/issues"
  },
  "author": "WSO2",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/cjs/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/thunder-id/thunderid",
    "directory": "sdks/react"
  },
  "scripts": {
    "build": "pnpm clean:dist &&  node rolldown.config.js && tsc -p tsconfig.lib.json --emitDeclarationOnly --outDir dist",
    "clean": "pnpm clean:node_modules && pnpm clean:dist",
    "clean:dist": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "format:check": "prettier --check --cache .",
    "format:fix": "prettier --write --cache .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.cjs,.mjs",
    "lint:fix": "eslint . --fix --ext .js,.jsx,.ts,.tsx,.cjs,.mjs",
    "test": "vitest",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "typecheck": "tsc -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@emotion/css": "catalog:",
    "@floating-ui/react": "catalog:",
    "@testing-library/react": "catalog:",
    "@thunderid/eslint-plugin": "workspace:^",
    "@thunderid/prettier-config": "workspace:^",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "dompurify": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@types/react": ">=16.8.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "@emotion/css": "catalog:",
    "@floating-ui/react": "catalog:",
    "@thunderid/browser": "workspace:^",
    "dompurify": "catalog:",
    "tslib": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
